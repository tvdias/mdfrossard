---
layout: layout.ejs
---

<%
var p = build_post({
    id: typeof id !== 'undefined' ? id : undefined,
    layout: typeof layout !== 'undefined' ? layout : 'post',
    title: typeof title !== 'undefined' ? title : '',
    author: typeof author !== 'undefined' ? author : undefined,
    description: typeof description !== 'undefined' ? description : undefined,
    featured_image: typeof featured_image !== 'undefined' ? featured_image : undefined,
    comments: typeof comments !== 'undefined' ? comments : undefined,
    date: typeof date !== 'undefined' ? date : undefined,
    url: page.url
}, content);

var authorName = typeof author !== 'undefined' ? author : config.author;
var currentAuthor = null;
if (authorName && site.data.authors) {
    currentAuthor = site.data.authors.find(a => a.name === authorName || a.name.includes(authorName));
}
if (!currentAuthor && site.data.authors) {
    currentAuthor = site.data.authors.find(a => a.main);
}
p.author = currentAuthor;

var wordCount = content.split(/\s+/).length;
var readingTime = Math.max(1, Math.round(wordCount / 200));
%>

<section class="section section-internal">
    <!-- Structured Data: BlogPosting -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": "<%= p.title %>",
      "description": "<%= p.description || '' %>",
      "image": "<%= new URL(p.featured_image || '/images/uploads/2024/md_odontologia_barra.webp', config.url).toString() %>",
      "author": {
        "@type": "Person",
        "name": "<%= p.author ? p.author.name : config.author %>"
      },
      "publisher": {
        "@type": "Organization",
        "name": "MD Frossard Odontologia",
        "logo": {
          "@type": "ImageObject",
          "url": "https://mdfrossard.com.br/images/logo-MD.jpg"
        }
      },
      "datePublished": "<%= p.date ? new Date(p.date).toISOString() : '' %>",
      "dateModified": "<%= (typeof updated !== 'undefined' && updated) ? new Date(updated).toISOString() : (p.date ? new Date(p.date).toISOString() : '') %>",
      "wordCount": <%= wordCount %>,
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "<%= new URL(p.url, config.url).toString() %>"
      }
    }
    </script>

    <!-- Structured Data: BreadcrumbList -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "<%= config.url %>/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Blog",
          "item": "<%= config.url %>/blog/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "<%= p.title %>",
          "item": "<%= new URL(p.url, config.url).toString() %>"
        }
      ]
    }
    </script>

    <% if (typeof faqs !== 'undefined' && faqs && faqs.length > 0) { %>
    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        <% faqs.forEach(function(faq, i) { %>
        {
          "@type": "Question",
          "name": "<%= faq.question %>",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "<%= faq.answer %>"
          }
        }<%= i < faqs.length - 1 ? ',' : '' %>
        <% }); %>
      ]
    }
    </script>
    <% } %>

    <div class="container">
        <div class="article-body">
            <!-- Back link -->
            <a href="/blog/" class="back-to-blog">
                <i data-lucide="arrow-left" style="width:1rem; height:1rem;"></i>
                Voltar ao Blog
            </a>

            <!-- Post meta -->
            <div class="post-hero-meta">
                <% if (typeof category !== 'undefined' && category) { %>
                <span class="post-tag"><i data-lucide="tag" style="width:0.7rem; height:0.7rem;"></i> <%= category %></span>
                <% } %>
                <span class="post-reading-time"><i data-lucide="clock" style="width:0.85rem; height:0.85rem;"></i> <%= readingTime %> min de leitura</span>
            </div>

            <!-- Título -->
            <h1 style="font-size: 2.25rem; line-height: 1.2; margin-bottom: 2rem;"><%= p.title %></h1>

            <% if (typeof intro_text !== 'undefined' && intro_text) { %>
                <div class="intro-text" style="font-size: 1.125rem; line-height: 1.8; color: #444; margin-bottom: 2rem;">
                    <%- markdown(intro_text) %>
                </div>
            <% } %>

            <img src="<%= p.featured_image || '/images/uploads/2024/md_odontologia_barra.webp' %>" loading="eager" fetchpriority="high" decoding="async" width="1200" height="675" alt="<%= p.title %>" class="article-img reveal">

            <div class="content reveal">
                <%- content %>
            </div>

            <% if (p.author && p.author.name) { %>
            <div class="author-box reveal">
                <div class="author-avatar">
                    <img src="<%= p.author.avatar %>" alt="<%= p.author.name %>" style="width:100%; height:100%; border-radius:50%; object-fit:cover; object-position: center top;">
                </div>
                <div class="author-info">
                    <h4><%= p.author.name %></h4>
                    <% if (p.author.specialty || p.author.cro) { %>
                    <p class="author-title">
                        <%= p.author.cro ? 'CRO ' + p.author.cro + ' · ' : '' %>
                        <%= p.author.specialty || 'Especialista' %>
                    </p>
                    <% } %>
                    <p><%- markdown(p.author.bio) %></p>
                </div>
            </div>
            <% } %>

            <div class="mt-5 text-center reveal">
                <a href="https://api.whatsapp.com/send?phone=5521976637803" onclick="return gtagSendEventWhatsapp(this.href)" class="btn btn-primary btn-lg">
                    <i data-lucide="message-circle" class="icon-sm"></i> Agende sua Consulta
                </a>
            </div>

            <!-- Local SEO: link contextual para money page -->
            <aside class="post-units-aside reveal" aria-label="Atendimento presencial">
                <p class="post-units-aside__title">Atendemos no Rio de Janeiro</p>
                <p class="post-units-aside__copy">
                    Este artigo foi escrito pela equipe da MD Frossard Odontologia, que atua há 38 anos na cidade. Conheça nossa unidade na <a href="/dentista-barra-da-tijuca/"><strong>Barra da Tijuca</strong></a> ou em <a href="/dentista-em-botafogo/"><strong>Botafogo</strong></a>.
                </p>
            </aside>
        </div>
    </div>
</section>

<style>
/* ── Post Layout ── */
.article-body {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 1rem;
}

.article-body h2 {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-main, #1a1a1a);
    margin: 4.5rem 0 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #c9a84c;
    display: inline-block;
    font-family: var(--font-heading);
}

.article-body h3 {
    font-size: 1.35rem;
    font-weight: 700;
    margin: 3.5rem 0 1.5rem;
    font-family: var(--font-heading);
}

.content p {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-main);
    margin: 0 0 2.5rem;
    font-family: var(--font-body);
}

.content ul {
    margin: 0 0 3rem 1.5rem;
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--text-main);
}

.content li {
    margin-bottom: 1rem;
}

.content a {
    color: #b08a20;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: all 0.2s ease;
}

.content a:hover {
    color: var(--text-main);
}

.content img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    margin: 4.5rem 0;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    display: block;
}

.post-hero-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
}

.post-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: #c9a84c;
    padding: 0.3rem 0.8rem;
    border-radius: 2rem;
}

.post-reading-time {
    font-size: 0.82rem;
    color: #888;
    display: flex;
    align-items: center;
    gap: 0.3rem;
}

.article-img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    margin: 2rem 0;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    display: block;
}

.author-box {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem;
    background: #f8f8f6;
    border-radius: 1rem;
    margin: 3rem 0;
    position: relative;
    z-index: 10;
}

.author-avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
}

.author-info h4 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 0.25rem;
}

.author-info .author-title {
    font-size: 0.75rem;
    color: #c9a84c;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.75rem;
}

.author-info p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #555;
    margin: 0;
}

.back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #888;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
}

.back-to-blog:hover {
    color: #c9a84c;
}

/* Post local-units aside (subtle internal link block) */
.post-units-aside {
    margin: 3rem 0 0;
    padding: 1.25rem 1.5rem;
    background: #faf7ee;
    border-left: 3px solid #c9a84c;
    border-radius: 6px;
}
.post-units-aside__title {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c9a84c;
    margin: 0 0 0.4rem;
}
.post-units-aside__copy {
    font-size: 0.95rem;
    color: #444;
    line-height: 1.6;
    margin: 0;
}
.post-units-aside__copy a {
    color: #1a1a1a;
    text-decoration: underline;
    text-underline-offset: 3px;
}
.post-units-aside__copy a:hover {
    color: #c9a84c;
}

/* ── Mobile (<= 760px): reduz espaçamentos exagerados e conserta underline H2 ── */
@media (max-width: 760px) {
    .article-body {
        padding: 0 1.1rem;
    }
    .article-body h1 {
        font-size: 1.65rem !important;
        line-height: 1.25 !important;
        margin-bottom: 1.25rem !important;
    }
    .article-body h2 {
        font-size: 1.3rem;
        margin: 2.5rem 0 1.25rem;
        display: block;       /* full-width underline */
        padding-bottom: 0.4rem;
    }
    .article-body h3 {
        font-size: 1.15rem;
        margin: 2rem 0 1rem;
    }
    .content p,
    .content ul {
        font-size: 1rem;
        line-height: 1.7;
    }
    .content p {
        margin: 0 0 1.4rem;
    }
    .content ul {
        margin: 0 0 1.6rem 1.3rem;
    }
    .content li {
        margin-bottom: 0.6rem;
    }
    .content img,
    .article-img {
        margin: 1.75rem 0 !important;
        border-radius: 0.75rem;
    }
    .author-box {
        gap: 1rem;
        padding: 1.25rem;
        margin: 2rem 0;
    }
    .post-hero-meta {
        gap: 0.6rem;
        margin-bottom: 1rem;
    }
    .intro-text {
        font-size: 1rem !important;
        line-height: 1.65 !important;
        margin-bottom: 1.5rem !important;
    }
}
</style>
