---
layout: layout.ejs
---

<!-- Page Mini Hero -->
<section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content reveal">
        <h1><%= title %></h1>
        <p><%= specialty %></p>
    </div>
</section>

<!-- Member Detail -->
<section class="member-detail section">
    <div class="container">
        <div class="member-grid">
            <div class="member-image reveal">
                <div class="member-img-wrapper">
                    <img src="<%= avatar %>" alt="<%= title %>" class="img-fluid rounded shadow-lg" loading="lazy" decoding="async">
                </div>
            </div>
            <div class="member-info reveal delay-1">
                <div class="breadcrumb">
                    <a href="/">Home</a>
                    <i data-lucide="chevron-right" class="icon-xs"></i>
                    <a href="/equipe/">Equipe</a>
                    <i data-lucide="chevron-right" class="icon-xs"></i>
                    <span><%= title %></span>
                </div>
                
                <h2><%= title %></h2>
                <span class="member-specialty"><%= specialty %></span>
                
                <div class="member-bio mt-4">
                    <%- content %>
                </div>
                
                <div class="member-cta mt-5">
                    <a href="https://api.whatsapp.com/send?phone=5521976637803" target="_blank" class="btn btn-primary">
                        <i data-lucide="calendar" class="icon-sm"></i> Agendar com <%= title.split(' ')[1] %>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.member-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: flex-start;
}

@media (min-width: 992px) {
    .member-grid {
        grid-template-columns: 1fr 1.5fr;
    }
}

.member-img-wrapper {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4/5;
}

.member-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.member-specialty {
    display: inline-block;
    color: #c9a84c;
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 20px;
}

.member-bio {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #444;
}

.member-info .breadcrumb {
    margin-bottom: 20px;
    opacity: 0.6;
}

.member-info .breadcrumb a {
    color: inherit;
    text-decoration: none;
}
</style>
