---
layout: layout.ejs
---

<%
// Helper to safely get data
const safeData = (key, fallback = '') => typeof data !== 'undefined' && data[key] ? data[key] : fallback;
%>

<!-- Treatment Hero -->
<section class="treatment-hero">
    <div class="treatment-hero-bg">
        <img src="<%= featured_image || '/images/hero-img.webp' %>" loading="lazy" decoding="async" alt="<%= title %>" fetchpriority="high">
    </div>
    <div class="treatment-hero-overlay"></div>
    <div class="container treatment-hero-content reveal">
        <div class="breadcrumb">
            <a href="/">Home</a>
            <i data-lucide="chevron-right" class="icon-xs"></i>
            <a href="/tratamentos/">Tratamentos</a>
            <i data-lucide="chevron-right" class="icon-xs"></i>
            <span><%= title.split('|')[0].trim() %></span>
        </div>
        <h1><%- title.replace('|', '<br>') %></h1>
        <p><%= description %></p>
        <div style="display:flex; gap:16px; flex-wrap:wrap;">
            <a href="https://api.whatsapp.com/send?phone=5521976637803" onclick="return gtagSendEventWhatsapp(this.href)" class="btn btn-primary btn-lg">Agendar Consulta</a>
            <% if (typeof faqs !== 'undefined' && faqs.length > 0) { %>
            <a href="#faq" class="btn btn-outline btn-lg">Ver Perguntas Frequentes</a>
            <% } %>
        </div>
    </div>
</section>

<%- content %>

<% if (typeof faqs !== 'undefined' && faqs.length > 0) { %>
<!-- FAQ Section -->
<section class="faq-section section" id="faq">
    <div class="container">
        <div class="section-header reveal">
            <h2>Perguntas Frequentes</h2>
            <p>Tire suas dúvidas sobre o tratamento de <%= title.split('|')[0].trim() %>.</p>
        </div>

        <div class="faq-list mt-5">
            <% faqs.forEach(function(faq, index) { %>
            <div class="faq-item reveal delay-<%= (index % 4) + 1 %>">
                <button class="faq-question">
                    <%= faq.question %>
                    <span class="faq-icon"><i data-lucide="plus" class="icon-sm"></i></span>
                </button>
                <div class="faq-answer">
                    <p><%- faq.answer %></p>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- CTA Section -->
<section class="treatment-cta reveal">
    <div class="container text-center">
        <h2>Pronto para recuperar o seu sorriso?</h2>
        <p>Agende uma consulta com nossos especialistas e descubra o plano de tratamento ideal para o seu caso.</p>
        <div class="cta-buttons">
            <a href="https://api.whatsapp.com/send?phone=5521976637803" onclick="return gtagSendEventWhatsapp(this.href)" class="btn btn-primary btn-lg">
                <i data-lucide="message-circle" class="icon-sm"></i> Chamar no WhatsApp
            </a>
            <a href="tel:2132170430" onclick="return gtagSendEventTelefone(this.href)" class="btn btn-outline btn-lg" style="color:white; border-color:white;">
                <i data-lucide="phone" class="icon-sm"></i> (21) 3217-0430
            </a>
        </div>
    </div>
</section>

<style>
/* ── Common Treatment Styles (New Template) ── */
.treatment-hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 60px;
    overflow: hidden;
}

.treatment-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
}

.treatment-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 10%;
}

@media (max-width: 768px) {
    .treatment-hero-bg img {
        object-position: 80% 10%;
    }
}

.treatment-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.3) 0%, rgba(10,10,10,0.85) 100%);
    z-index: 1;
}

.treatment-hero-content {
    position: relative;
    z-index: 2;
    color: white;
    padding-top: 220px;
}

.breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    opacity: 0.7;
    margin-bottom: 20px;
    color: white;
}

.breadcrumb a {
    color: white;
}

.treatment-hero-content h1 {
    color: white;
    font-size: 2.75rem;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 16px;
    max-width: 700px;
}

.treatment-hero-content p {
    font-size: 1.125rem;
    color: white;
    opacity: 0.85;
    max-width: 600px;
    margin-bottom: 32px;
}

/* Intro grid (general for content body) */
.intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
}

@media (min-width: 992px) {
    .intro-grid { grid-template-columns: 1fr 1fr; }
}

.treatment-intro {
    background: var(--bg-white);
}

.intro-text h2 {
    font-size: 2.25rem;
    font-weight: 800;
    margin-bottom: 24px;
    color: var(--primary-dark);
}

.intro-text p {
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 16px;
}

.intro-text p:last-of-type {
    margin-bottom: 0;
}

/* FAQ */
.faq-section {
    background: var(--bg-light);
}

.faq-list {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.faq-item {
    background: white;
    border-radius: var(--border-radius-sm);
    border: 1px solid rgba(0,0,0,0.06);
    overflow: hidden;
    transition: box-shadow 0.3s ease;
}

.faq-item.open {
    box-shadow: var(--shadow-sm);
}

.faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 22px 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    color: var(--primary-dark);
    transition: color 0.2s ease;
}

.faq-question:hover {
    color: var(--brand-primary);
}

.faq-item.open .faq-question {
    color: var(--brand-primary);
}

.faq-icon {
    width: 32px;
    height: 32px;
    min-width: 32px;
    background: var(--bg-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-primary);
    transition: transform 0.3s ease, background 0.2s ease;
}

.faq-item.open .faq-icon {
    background: var(--brand-primary);
    color: white;
    transform: rotate(45deg);
}

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease, padding 0.35s ease;
    padding: 0 24px;
}

.faq-item.open .faq-answer {
    max-height: 500px; /* Suficiente para a resposta */
    padding: 0 24px 22px;
}

.faq-answer p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
}

.faq-answer ul {
    list-style: disc;
    padding-left: 20px;
    margin-top: 10px;
}

/* CTA */
.treatment-cta {
    background: linear-gradient(135deg, var(--bg-dark) 0%, #1a1814 100%);
    padding: 80px 0;
    position: relative;
    overflow: hidden;
    color: white;
    text-align: center;
}

.treatment-cta::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212,175,55,0.12) 0%, transparent 70%);
}

.treatment-cta h2 {
    position: relative;
    z-index: 2;
    font-size: 2.25rem;
    margin-bottom: 16px;
    color: white;
}

.treatment-cta p {
    position: relative;
    z-index: 2;
    color: rgba(255,255,255,0.7);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto 36px;
}

.cta-buttons {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    justify-content: center;
}

@media (min-width: 640px) {
    .cta-buttons { flex-direction: row; }
}

@media (max-width: 768px) {
    .treatment-hero-content h1 { font-size: 2.25rem; }
    .treatment-cta h2 { font-size: 1.75rem; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // FAQ Accordion
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
        const btn = item.querySelector('.faq-question');
        btn.addEventListener('click', () => {
            const isOpen = item.classList.contains('open');
            // Fechar todos
            faqItems.forEach(i => i.classList.remove('open'));
            // Abrir o clicado (se estava fechado)
            if (!isOpen) item.classList.add('open');
        });
    });
});
</script>
