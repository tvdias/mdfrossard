<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% var pageTitle = typeof title !== 'undefined' ? title : ''; %>
    <title><%= pageTitle || config.title %></title>
    
    <% var pageDescription = typeof description !== 'undefined' ? description : config.description; %>
    <meta name="description" content="<%= pageDescription %>">
    
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon"/>
    
    <!-- Landing Pages: bloquear indexação orgânica -->
    <meta name="robots" content="noindex, nofollow">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Preconnect: Google Tag Manager, GA4, Ads -->
    <link rel="preconnect" href="https://www.googletagmanager.com">
    <link rel="preconnect" href="https://www.google-analytics.com">
    <link rel="preconnect" href="https://s3-sa-east-1.amazonaws.com">
    <link rel="dns-prefetch" href="https://s3-sa-east-1.amazonaws.com">
    <link rel="dns-prefetch" href="https://googleads.g.doubleclick.net">
    <link rel="dns-prefetch" href="https://www.google.com">
    <link rel="dns-prefetch" href="https://api.whatsapp.com">
    <% if (typeof google_fonts !== 'undefined' && google_fonts) { %>
    <!-- Google Fonts: carregamento não-bloqueante para melhor LCP/FCP -->
    <link href="https://fonts.googleapis.com/css2?family=<%= google_fonts %>&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=<%= google_fonts %>&display=swap" rel="stylesheet"></noscript>
    <% } %>
    
    <% if (typeof canonical !== 'undefined' && canonical) { %>
    <link rel="canonical" href="<%= canonical %>">
    <% } %>

    <% if (typeof hero_preload !== 'undefined' && hero_preload) { %>
    <link rel="preload" as="image" href="<%= hero_preload %>" fetchpriority="high" type="image/webp">
    <% } %>

    <%- open_graph({
      title: pageTitle,
      description: pageDescription,
      url: page.url,
      image: typeof og_image !== 'undefined' ? og_image : ''
    }) %>

    <%- include('_partial/consent-default') %>
    <%- include('_partial/gtm') %>
    <%- include('_partial/google-tag') %>

    <%- include('_partial/fb-pixel') %>
    <%- include('_partial/phonetrack') %>

    <%- include('_partial/org-schema') %>
</head>
<body style="margin: 0; padding: 0;">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TLR2C2T"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <%- content %>
    <%- include('_partial/consent-banner') %>
    <%- include('_partial/delay-engine') %>
    <%- include('_partial/analytics-events') %>

</body>
</html>
