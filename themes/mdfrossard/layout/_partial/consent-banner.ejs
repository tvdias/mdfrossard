<!-- ═══════════════════════════════════════════════════════════
     LGPD Consent Banner — partial compartilhado
     Aplica Google Consent Mode v2 (gtag) e Meta Consent Mode
     (fbq) na mesma decisão do usuário. O default-denied já é
     disparado antes do gtag em consent-default.ejs.
     CSS escopado em .lgpd-* — não colide com estilos das LPs.
     ═══════════════════════════════════════════════════════════ -->
<style>
.lgpd-banner{
  position:fixed;bottom:0;left:0;right:0;z-index:10000;
  background:#0b1420;color:#fff;
  border-top:2px solid #c9a227;
  box-shadow:0 -8px 32px rgba(0,0,0,.35);
  padding:16px 20px;
  padding-bottom:calc(16px + env(safe-area-inset-bottom,0px));
  transform:translateY(110%);
  transition:transform .4s cubic-bezier(.4,0,.2,1);
  font-family:'Inter',system-ui,-apple-system,sans-serif;
}
.lgpd-banner.show{transform:translateY(0)}
.lgpd-inner{
  max-width:1100px;margin:0 auto;
  display:flex;flex-wrap:wrap;align-items:center;gap:16px;
  justify-content:space-between;
}
.lgpd-text{
  flex:1 1 300px;margin:0;
  font-size:.85rem;line-height:1.55;color:rgba(255,255,255,.82);
}
.lgpd-text strong{color:#fff;font-weight:600;}
.lgpd-text a{color:#e6c76a;text-decoration:underline}
.lgpd-btns{display:flex;flex-wrap:wrap;align-items:center;gap:14px;flex-shrink:0}
.lgpd-btn-accept{
  padding:10px 24px;border-radius:50px;
  font-family:'Outfit','Inter',system-ui,sans-serif;
  font-weight:700;font-size:.85rem;
  border:none;cursor:pointer;
  background:linear-gradient(135deg,#e6c76a,#c9a227);color:#0b1420;
  transition:transform .25s cubic-bezier(.4,0,.2,1),
             box-shadow .25s cubic-bezier(.4,0,.2,1);
  white-space:nowrap;min-height:40px;
}
.lgpd-btn-accept:hover{
  transform:translateY(-2px);box-shadow:0 8px 20px rgba(201,162,39,.35);
}
.lgpd-btn-reject{
  background:none;border:none;cursor:pointer;
  color:rgba(255,255,255,.45);
  font-size:.78rem;font-family:'Inter',system-ui,sans-serif;
  text-decoration:underline;padding:4px 0;
  transition:color .2s;
  white-space:nowrap;
}
.lgpd-btn-reject:hover{color:rgba(255,255,255,.72);}
@media (max-width:760px){
  .lgpd-banner{
    padding:10px 12px;
    padding-bottom:calc(10px + env(safe-area-inset-bottom,0px));
  }
  .lgpd-inner{flex-wrap:nowrap;align-items:center;gap:10px;}
  .lgpd-text{flex:1 1 0;font-size:.72rem;line-height:1.4;min-width:0;}
  .lgpd-btns{flex-wrap:nowrap;gap:8px;}
  .lgpd-btn-accept{padding:9px 18px;font-size:.78rem;min-height:38px;}
  .lgpd-btn-reject{font-size:.7rem;}
  .lgpd-text-full{display:none;}
  .lgpd-text-short{display:inline;}
}
/* FAB WhatsApp (desktop) e barra de contato (mobile) sobem para cima do
   banner enquanto ele está visível — nunca esconder o CTA principal.
   --lgpd-h é definida via JS com a altura real do banner + folga. */
body.lgpd-visible .sticky-wpp,
body.lgpd-visible .whatsapp-float,
body.lgpd-visible .whatsapp-fab{
  transform:translateY(calc(-1 * var(--lgpd-h, 96px)));
  transition:transform .4s cubic-bezier(.4,0,.2,1);
}
body.lgpd-visible .sticky-bar{
  transform:translateY(calc(-1 * var(--lgpd-h, 72px)));
  transition:transform .4s cubic-bezier(.4,0,.2,1);
}
</style>

<div class="lgpd-banner" id="lgpd-banner" role="dialog" aria-label="Aviso de privacidade" aria-live="polite">
  <div class="lgpd-inner">
    <p class="lgpd-text">
      <span class="lgpd-text-full">🍪 <strong>Usamos cookies</strong> para melhorar sua experiência no site, entender o que funciona melhor e exibir conteúdo relevante. Suas informações são tratadas com cuidado e sigilo, conforme nossa <a href="/privacidade/" target="_blank" rel="noopener">Política de Privacidade</a>.</span>
      <span class="lgpd-text-short" style="display:none;">🍪 <strong>Usamos cookies</strong> para melhorar o site. <a href="/privacidade/" target="_blank" rel="noopener">Saiba mais</a></span>
    </p>
    <div class="lgpd-btns">
      <button type="button" class="lgpd-btn-reject" onclick="mdfConsent('denied')">Recusar</button>
      <button type="button" class="lgpd-btn-accept" onclick="mdfConsent('granted')">Aceitar cookies</button>
    </div>
  </div>
</div>

<script>
(function(){
  var KEY = 'mdf_consent_v1';
  var banner = document.getElementById('lgpd-banner');
  if (!banner) return;
  var stored = null;
  try { stored = localStorage.getItem(KEY); } catch(e) {}
  // Altura real do banner -> CSS var usada para deslocar o FAB/sticky-bar
  // para cima do banner (em vez de escondê-los).
  function setBannerH(){
    try {
      document.documentElement.style.setProperty('--lgpd-h', (banner.offsetHeight + 12) + 'px');
    } catch(e) {}
  }
  window.addEventListener('resize', setBannerH);
  if (!stored) {
    var showBanner = function(){
      setBannerH();
      banner.classList.add('show');
      document.body.classList.add('lgpd-visible');
    };
    // Exibição imediata (300ms, só para o primeiro paint): cada segundo de
    // atraso reduz a taxa de decisão — e sem decisão o Pixel/CAPI ficam mudos.
    setTimeout(showBanner, 300);
  }
  // Aplica decisão do usuário ao Google Consent Mode (gtag) e Meta (fbq)
  function applyConsent(decision){
    // Google Consent Mode v2
    if (typeof gtag === 'function') {
      if (decision === 'granted') {
        gtag('consent','update',{
          'ad_storage':'granted',
          'ad_user_data':'granted',
          'ad_personalization':'granted',
          'analytics_storage':'granted'
        });
      } else {
        gtag('consent','update',{
          'ad_storage':'denied',
          'ad_user_data':'denied',
          'ad_personalization':'denied',
          'analytics_storage':'denied'
        });
      }
    }
    // Meta Consent Mode (libera/segura a fila do Pixel)
    if (typeof fbq === 'function') {
      fbq('consent', decision === 'granted' ? 'grant' : 'revoke');
    }
  }

  window.mdfConsent = function(decision){
    try { localStorage.setItem(KEY, decision); } catch(e) {}
    applyConsent(decision);
    // Notifica scripts dependentes de consent (ex: Microsoft UET)
    if (decision === 'granted') {
      window.dispatchEvent(new CustomEvent('mdf:consent:granted'));
    }
    banner.classList.remove('show');
    document.body.classList.remove('lgpd-visible');
  };
  // Permite revogar consent + reabrir banner a partir da página de privacidade
  window.mdfConsentReopen = function(){
    try { localStorage.removeItem(KEY); } catch(e) {}
    applyConsent('denied');
    setBannerH();
    banner.classList.add('show');
    document.body.classList.add('lgpd-visible');
  };
})();
</script>
