<head>
    <%- include('consent-default') %>
    <%- include('gtm') %>
    <%
    var pageTitle = typeof title !== 'undefined' ? title : '';
    var pageDescription = typeof description !== 'undefined' ? description : config.description;
    var pageFeaturedImage = typeof featured_image !== 'undefined' ? featured_image : undefined;
    var pageUrl = page && page.url ? page.url : '/';
    %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle ? (pageTitle + " | " + config.title) : config.title %></title>

    <!-- Meta Tags -->
    <meta name="description" content="<%= pageDescription %>">
    <meta name="theme-color" content="#0a0a0a">

    <% if (pageFeaturedImage) { %>
    <link rel="preload" as="image" href="<%= pageFeaturedImage %>" fetchpriority="high">
    <% } %>

    <!-- Preconnects: reduz latência dos domínios críticos -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://www.googletagmanager.com">
    <link rel="preconnect" href="https://www.google-analytics.com">
    <link rel="preconnect" href="https://connect.facebook.net">
    <link rel="dns-prefetch" href="https://s3-sa-east-1.amazonaws.com">
    <link rel="dns-prefetch" href="https://googleads.g.doubleclick.net">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"></noscript>

    <!-- Icons (Lucide) -->
    <script defer src="https://unpkg.com/lucide@0.383.0/dist/umd/lucide.min.js"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/styles.css">

    <link rel="canonical" href="<%= new URL(pageUrl, config.url).toString() %>" />
    <link rel="icon" href="/images/favicon.ico" type="image/x-icon"/>  
    <link rel="alternate" type="application/atom+xml" title="Feed para <%= config.title %>" href="<%= config.url %>/atom.xml" />
    
    <%- open_graph({
      title: pageTitle,
      description: pageDescription,
      image: pageFeaturedImage,
      url: pageUrl
    }) %>

    <%- include('google-tag') %>
    
    <%- include('fb-pixel') %>
</head>
