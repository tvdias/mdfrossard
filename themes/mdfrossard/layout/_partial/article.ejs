<article id="<%= post.layout %>-<%= post.id %>" class="l-light <%= post.layout %>-<%= post.id %> <%= post.layout %> type-<%= post.layout %>-<%= post.id %> status-publish format-standard has-post-thumbnail hentry category-sem-categoria" itemscope itemprop="blogPost">
  <header>
    <%- include('post/title', {post: post, index: index, class_name: 'article-title'}) %>
    <div>Por <%= post.author && post.author.length > 0 ? post.author : config.author %></div>
    <%- include('post/featured_image', {post: post}) %>
  </header>
  <div class="post-content article-inner" itemprop="articleBody">
    <% if (index && (post.description || post.excerpt)) { %>
      <% if (post.description) { %>
        <p><%- post.description %></p>
      <% } else { %>
        <%- post.excerpt %>
      <% } %>
      <% if (theme.excerpt_link){ %>
      <a href="<%- url_for(post.url) %>" class="more" title="<%= post.title %>"><%= theme.excerpt_link %></a>
      <% } %>
    <% } else { %>
      <%- post.content %>
    <% } %>
  </div>
  <!-- articleBody -->
  <footer class="post-footer">
    <% if (!index){ %>
      <%- include('sliders/marque_avaliacao') %>
      <%- include('post/share') %>
      <%- include('post/author', {post: post}) %>
      <%- include('post/comments', {post: post}) %>
    <% } %>
  </footer>
</article>