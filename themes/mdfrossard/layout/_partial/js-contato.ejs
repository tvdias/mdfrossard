<script>
// Gera UUID v4 — usado como event_id para deduplicar fbq client + CAPI server.
// Fallback simples para browsers antigos sem crypto.randomUUID.
function mdfUuid() {
    if (typeof crypto !== 'undefined' && crypto.randomUUID) {
        return crypto.randomUUID();
    }
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
        var r = Math.random() * 16 | 0;
        var v = c === 'x' ? r : (r & 0x3 | 0x8);
        return v.toString(16);
    });
}

$jq("#contactform").submit(function(e) {
    e.preventDefault();
    var $form = $jq(this);
    $form.find(":submit").attr("disabled", true);
    $form.find(".ajax-loader").addClass("is-active");

    // Mesmo event_id no browser e no servidor permite à Meta deduplicar.
    var eventId = mdfUuid();

    var data = {
        'name': $form.find("input[name=name]").val(),
        'email': $form.find("input[name=email]").val(),
        'phone': $form.find("input[name=phone]").val() || $form.find("input[name=telefone]").val() || '',
        'subject': $form.find("input[name=subject]").val(),
        'message': $form.find("textarea[name=message]").val(),
        'website': $form.find("input[name=website]").val(),
        'event_id': eventId
    };

    // Lead client-side (fbq) — só dispara de fato se o usuário aceitou o consent.
    // Se ainda não aceitou, fica em fila (graças ao revoke em fb-pixel.ejs)
    // e libera quando o banner emitir grant.
    if (typeof fbq === 'function') {
        fbq('track', 'Lead', {
            content_name: data.subject ? String(data.subject).slice(0, 100) : 'Formulário Contato',
            content_category: 'site_form'
        }, { eventID: eventId });
    }

    // Espelha como GA4 também — útil para conversion tracking no Google Ads.
    if (typeof gtag === 'function') {
        gtag('event', 'generate_lead', {
            event_category: 'Engagement',
            event_label: data.subject || 'Contato',
            lead_source: window.location.pathname
        });
    }

    return fetch('/api/contact', {
        body: JSON.stringify(data),
        headers: {
            'Content-Type': 'application/json'
        },
        method: 'POST'
    })
    .then(response => {
        console.log('API response', response);
        if (response.status >= 400) { showError($form); }
        else { showSuccess($form); }
    })
    .catch(function(error) {
        showError($form);
    });
});

function showError($form) {
    $form.find(".ajax-loader").removeClass("is-active");
    $form.find(":submit").attr("disabled", false);
    $form.find(".wpcf7-response-output").text("Ocorreu um erro ao enviar a sua mensagem. Por favor tente novamente.");
    $form.find(".wpcf7-response-output").removeClass("wpcf7-display-none").removeClass("wpcf7-mail-sent-ok");
}

function showSuccess($form) {
    $form.find(".ajax-loader").removeClass("is-active");
    $form.find(".wpcf7-response-output").removeClass("wpcf7-display-none").addClass("wpcf7-mail-sent-ok");
}
</script>
