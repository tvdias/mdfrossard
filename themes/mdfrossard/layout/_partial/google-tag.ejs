  if (typeof gtag !== 'function') { function gtag(){dataLayer.push(arguments);} }
  gtag('js', new Date());
  gtag('config', 'AW-1003091018');
  gtag('config', 'G-7S27172376');
</script>
<!-- Execução real adiada ao delay-engine. Script já em cache pelo preload acima. -->
