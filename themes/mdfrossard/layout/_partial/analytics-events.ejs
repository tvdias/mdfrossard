<!-- Universal GA4 Contact Tracking + Meta Pixel + CAPI beacon -->
<!-- Valor da conversão atribuído por LP via front-matter `contact_value`.
     Páginas sem contact_value não enviam value/currency (Meta/Google contam
     a conversão sem valor monetário, comportamento idêntico ao anterior). -->
<% if (typeof page !== 'undefined' && page.contact_value) { %>
<script>window.MDF_CONTACT_VALUE = <%= page.contact_value %>; window.MDF_CONTACT_CURRENCY = 'BRL';</script>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Função para disparar eventos com segurança
    function trackLead(eventName, label) {
        if (typeof gtag === 'function') {
            gtag('event', eventName, {
                'event_category': 'Engagement',
                'event_label': label,
                'lead_source': window.location.pathname
            });
        } else if (typeof dataLayer !== 'undefined') {
            dataLayer.push({
                'event': eventName,
                'event_category': 'Engagement',
                'event_label': label,
                'lead_source': window.location.pathname
            });
        }
    }

    // Monitor Global de Cliques (Rede de Segurança e Cobertura Total)
    document.addEventListener('click', function(e) {
        var anchor = e.target.closest('a');
        if (!anchor) return;

        var href = anchor.href || '';
        var hasManualTracking = anchor.getAttribute('onclick') && anchor.getAttribute('onclick').includes('gtagSendEvent');

        // Se o link já tem rastreamento manual, não interferimos
        if (hasManualTracking) return;

        // Rastrear Cliques em WhatsApp automaticamente
        if (href.indexOf('api.whatsapp.com') !== -1 || href.indexOf('wa.me') !== -1) {
            e.preventDefault();
            gtagSendEventWhatsapp(href);
        }

        // Rastrear Cliques em Telefone automaticamente
        else if (href.indexOf('tel:') === 0) {
            e.preventDefault();
            gtagSendEventTelefone(href);
        }
    });
});
</script>

<!-- Google tag (gtag.js) event - delayed navigation helpers + Meta CAPI beacon -->
<!-- Eventos client (fbq) e server (CAPI) compartilham o mesmo event_id para deduplicação. -->
<!-- Value-based bidding: lê window.MDF_CONTACT_VALUE (definido por LP via front-matter)
     e propaga para gtag (Google Ads/GA4), fbq (Meta Pixel) e beacon CAPI. -->
<script>
  // UUID v4 (event_id para deduplicação browser ↔ server)
  function mdfUuidV4() {
    if (typeof crypto !== 'undefined' && crypto.randomUUID) return crypto.randomUUID();
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0;
      var v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  // Respeita LGPD: só envia para CAPI se o usuário aceitou o consent.
  function mdfConsentGranted() {
    try { return localStorage.getItem('mdf_consent_v1') === 'granted'; }
    catch(e) { return false; }
  }

  // Lê valor de conversão da página (definido em window.MDF_CONTACT_VALUE pelo
  // front-matter da LP). Retorna { value, currency } ou null se não definido.
  function mdfContactValue() {
    if (typeof window.MDF_CONTACT_VALUE !== 'number' || !window.MDF_CONTACT_VALUE) return null;
    return {
      value: window.MDF_CONTACT_VALUE,
      currency: window.MDF_CONTACT_CURRENCY || 'BRL'
    };
  }

  // Envia beacon assíncrono para /api/track-contact.
  // sendBeacon garante entrega mesmo após unload da página (a navegação WA/tel
  // dispara em paralelo). Fallback para fetch keepalive se sendBeacon falhar.
  function mdfBeaconContact(channel, eventId) {
    if (!mdfConsentGranted()) return;
    var payload = {
      event_id: eventId,
      channel: channel,
      source_url: window.location.href
    };
    var v = mdfContactValue();
    if (v) { payload.value = v.value; payload.currency = v.currency; }
    var data = JSON.stringify(payload);
    try {
      if (navigator.sendBeacon) {
        var blob = new Blob([data], { type: 'application/json' });
        if (navigator.sendBeacon('/api/track-contact', blob)) return;
      }
    } catch(e) {}
    try {
      fetch('/api/track-contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: data,
        keepalive: true,
        credentials: 'same-origin'
      });
    } catch(e) {}
  }

  // Helper Universal seguro. Dispara o callback mesmo que o GTM ainda não tenha processado
  function safeExecuteCallback(callback, timeoutMs) {
    var executed = false;
    var safeCb = function() {
      if (!executed) {
        executed = true;
        callback();
      }
    };
    setTimeout(safeCb, timeoutMs || 2000);
    return safeCb;
  }

  // WhatsApp: aguarda confirmação do evento contato_whatsapp antes de navegar
  function gtagSendEventWhatsapp(url) {
    var eventId = mdfUuidV4();
    var v = mdfContactValue();
    var callback = function () {
      if (typeof url === 'string') {
        window.location = url;
      }
    };
    var safeCb = safeExecuteCallback(callback, 2000);
    if (typeof gtag === 'function') {
      var gtagParams = {
        'event_category': 'Engagement',
        'event_callback': safeCb,
        'event_timeout': 2000
      };
      if (v) { gtagParams.value = v.value; gtagParams.currency = v.currency; }
      gtag('event', 'contato_whatsapp', gtagParams);
    } else {
      safeCb();
    }
    if (typeof fbq === 'function') {
      var fbqParams = { content_category: 'whatsapp' };
      if (v) { fbqParams.value = v.value; fbqParams.currency = v.currency; }
      fbq('track', 'Contact', fbqParams, { eventID: eventId });
    }
    mdfBeaconContact('whatsapp', eventId);
    return false;
  }

  // Telefone (GA4): aguarda confirmação do evento contato_telefone antes de navegar
  function gtagSendEventTelefone(url) {
    var eventId = mdfUuidV4();
    var v = mdfContactValue();
    if (typeof gtag === 'function') {
      gtag('event', 'PHT Calls');
    }
    var callback = function () {
      if (typeof url === 'string') {
        window.location = url;
      }
    };
    var safeCb = safeExecuteCallback(callback, 2000);
    if (typeof gtag === 'function') {
      var gtagParams = {
        'event_category': 'Engagement',
        'event_callback': safeCb,
        'event_timeout': 2000
      };
      if (v) { gtagParams.value = v.value; gtagParams.currency = v.currency; }
      gtag('event', 'contato_telefone', gtagParams);
    } else {
      safeCb();
    }
    if (typeof fbq === 'function') {
      var fbqParams = { content_category: 'phone' };
      if (v) { fbqParams.value = v.value; fbqParams.currency = v.currency; }
      fbq('track', 'Contact', fbqParams, { eventID: eventId });
    }
    mdfBeaconContact('phone', eventId);
    return false;
  }
</script>
