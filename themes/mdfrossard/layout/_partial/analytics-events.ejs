<!-- Universal GA4 Contact Tracking -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Função para disparar eventos com segurança
    function trackLead(eventName, label) {
        if (typeof gtag === 'function') {
            gtag('event', eventName, {
                'event_category': 'Engagement',
                'event_label': label,
                'lead_source': window.location.pathname
            });
            console.log('Lead Tracked: ' + eventName + ' (' + label + ')');
        } else if (typeof dataLayer !== 'undefined') {
            dataLayer.push({
                'event': eventName,
                'event_category': 'Engagement',
                'event_label': label,
                'lead_source': window.location.pathname
            });
            console.log('Lead Tracked via DataLayer: ' + eventName);
        }
    }

    // Monitorar todos os cliques no site
    document.addEventListener('click', function(e) {
        var anchor = e.target.closest('a');
        if (!anchor) return;

        var href = anchor.href || '';
        
        // Rastrear Cliques em WhatsApp
        if (href.indexOf('api.whatsapp.com') !== -1 || href.indexOf('wa.me') !== -1) {
            trackLead('contato_whatsapp', 'WhatsApp Click');
        } 
        
        // Rastrear Cliques em Telefone
        else if (href.indexOf('tel:') === 0) {
            trackLead('contato_telefone', 'Phone Click');
        }
    });
});
</script>

<!-- Google tag (gtag.js) event - delayed navigation helpers -->
<!-- Gerado pelo Google Ads para garantir envio do evento antes da navegação -->
<script>
  // WhatsApp: aguarda confirmação do evento contato_whatsapp antes de navegar
  function gtagSendEventWhatsapp(url) {
    var callback = function () {
      if (typeof url === 'string') {
        window.location = url;
      }
    };
    gtag('event', 'contato_whatsapp', {
      'event_callback': callback,
      'event_timeout': 2000
    });
    return false;
  }

  // Telefone (GA4): aguarda confirmação do evento contato_telefone antes de navegar
  function gtagSendEventTelefone(url) {
    // Dispara PHT Calls imediatamente (conversão Google Ads)
    if (typeof gtag === 'function') {
      gtag('event', 'PHT Calls');
    }
    // Dispara contato_telefone com callback de navegação
    var callback = function () {
      if (typeof url === 'string') {
        window.location = url;
      }
    };
    gtag('event', 'contato_telefone', {
      'event_callback': callback,
      'event_timeout': 2000
    });
    return false;
  }
  // PHT Calls (Google Ads): aguarda confirmação do evento antes de navegar
  function gtagSendEventPHTCalls(url) {
    var callback = function () {
      if (typeof url === 'string') {
        window.location = url;
      }
    };
    gtag('event', 'PHT Calls', {
      'event_callback': callback,
      'event_timeout': 2000
    });
    return false;
  }
</script>
