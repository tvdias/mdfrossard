<!-- ═══ LGPD / Google Consent Mode v2 — DEFAULT DENIED ═══
     DEVE rodar ANTES de qualquer gtag/gtm. Se o usuário já
     consentiu em visita anterior, lê o localStorage e libera. -->
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  (function(){
    var stored = null;
    try { stored = localStorage.getItem('mdf_consent_v1'); } catch(e) {}
    if (stored === 'granted') {
      gtag('consent','default',{
        'ad_storage':'granted',
        'ad_user_data':'granted',
        'ad_personalization':'granted',
        'analytics_storage':'granted',
        'functionality_storage':'granted',
        'security_storage':'granted'
      });
    } else {
      gtag('consent','default',{
        'ad_storage':'denied',
        'ad_user_data':'denied',
        'ad_personalization':'denied',
        'analytics_storage':'denied',
        'functionality_storage':'granted',
        'security_storage':'granted',
        'wait_for_update': 500
      });
    }
  })();
</script>
