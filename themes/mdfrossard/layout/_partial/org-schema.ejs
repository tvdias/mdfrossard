<!-- Structured Data: Dentist — 3 blocos JSON-LD independentes (aceito pelo Google).
     Bloco 1: organização-mãe (identidade, redes, contato).
     Bloco 2: unidade Barra da Tijuca (geo + hasMap para ranking no Maps).
     Bloco 3: unidade Botafogo (geo + hasMap para ranking no Maps).
     Posts (post.ejs) e LPs (landing_page.ejs) têm schemas próprios — sem conflito.
     aggregateRating removido: Google ignora notas autodeclaradas (self-serving reviews). -->

<!-- Bloco 1: Organização-mãe -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Dentist",
  "@id": "https://mdfrossard.com.br/#organization",
  "name": "MD Frossard Odontologia",
  "url": "https://mdfrossard.com.br/",
  "logo": "https://mdfrossard.com.br/images/logo-MD.jpg",
  "image": "https://mdfrossard.com.br/images/lps/equipe-md-frossard-odontologia.webp",
  "email": "contato@mdfrossard.com.br",
  "priceRange": "$$$",
  "medicalSpecialty": ["Dentistry", "Prosthodontics", "OralSurgery", "Periodontology"],
  "availableService": [
    { "@type": "MedicalProcedure", "name": "Implante Dentário" },
    { "@type": "MedicalProcedure", "name": "Prótese Dentária" },
    { "@type": "MedicalProcedure", "name": "Facetas e Estética Dental" },
    { "@type": "MedicalProcedure", "name": "Ortodontia" },
    { "@type": "MedicalProcedure", "name": "Periodontia" },
    { "@type": "MedicalProcedure", "name": "Endodontia" }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+5521976637803",
    "contactType": "customer service",
    "availableLanguage": "pt-BR",
    "areaServed": "BR"
  },
  "sameAs": [
    "https://www.facebook.com/MdFrossardOdontologia/",
    "https://www.instagram.com/md_frossard_odontologia/"
  ]
}
</script>

