---
layout: layout.ejs
---

<div class="row" style="margin-top: 30px;">
    <div class="col-md-9 col-sm-8 col-xs-12 contblog pull-right">
        <% posts.forEach(function(postEntry) { %>
        <%- include('_partial/article', {post: build_post(postEntry), index: true}) %>
        <% }) %>

        <% if (pagination && pagination.pages && pagination.pages.length > 1) { %>
        <nav id="page-nav" class="pagination">
            <% if (pagination.href.previous) { %>
            <a class="extend prev" rel="prev" href="<%= pagination.href.previous %>">&laquo; Anterior</a>
            <% } %>
            <% pagination.hrefs.forEach(function(href, indexNumber) { %>
            <a class="page-number<%= href === page.url ? ' current' : '' %>" href="<%= href %>"><%= indexNumber + 1 %></a>
            <% }) %>
            <% if (pagination.href.next) { %>
            <a class="extend next" rel="next" href="<%= pagination.href.next %>">Próximo &raquo;</a>
            <% } %>
        </nav>
        <% } %>
    </div>
    <!-- col -->
    <div class="col-md-3 col-sm-4 col-xs-12 contsidebar pull-left">
        <%- include('_partial/sidebar') %>
    </div>
    <!-- col -->           
</div>