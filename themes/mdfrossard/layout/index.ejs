---
layout: layout.ejs
---

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content reveal">
        <h1><%= title %></h1>
        <p>Dicas, curiosidades e artigos sobre saúde bucal escritos pelos especialistas da MD Frossard.</p>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section-header reveal">
            <h2>Artigos Recentes</h2>
            <p>Fique por dentro das novidades em odontologia e cuide melhor do seu sorriso.</p>
        </div>

        <div class="blog-grid">
            <% posts.forEach(function(postEntry, index) { %>
                <%- include('_partial/article_card', {post: build_post(postEntry), index: index}) %>
            <% }) %>
        </div>

        <% if (pagination && pagination.pages && pagination.pages.length > 1) { %>
        <nav id="page-nav" class="pagination mt-5">
            <% if (pagination.href.previous) { %>
            <a class="btn btn-outline" href="<%= pagination.href.previous %>">&laquo; Anterior</a>
            <% } %>
            <% pagination.hrefs.forEach(function(href, indexNumber) { %>
            <a class="page-number<%= href === page.url ? ' active' : '' %>" href="<%= href %>"><%= indexNumber + 1 %></a>
            <% }) %>
            <% if (pagination.href.next) { %>
            <a class="btn btn-outline" href="<%= pagination.href.next %>">Próximo &raquo;</a>
            <% } %>
        </nav>
        <% } %>
    </div>
</section>

<style>
/* ── Blog Grid ──────────────────────────────────── */
.blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
}

.blog-card {
    background: var(--bg-card, #fff);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
    display: flex;
    flex-direction: column;
    transition: transform 0.25s, box-shadow 0.25s;
    position: relative;
}

.blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.13);
}

.blog-card__thumb {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #eee;
    position: relative;
}

.blog-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
}

.blog-card:hover .blog-card__thumb img {
    transform: scale(1.08);
}

.blog-card__body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.blog-card__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #c9a84c;
}

.blog-card__title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    color: var(--text-main, #1a1a1a);
    margin: 0;
}

.blog-card__excerpt {
    font-size: 0.875rem;
    color: var(--text-muted, #666);
    line-height: 1.6;
    margin: 0;
    flex: 1;
}

.blog-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #c9a84c;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: gap 0.2s;
}

.blog-card__link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 10;
}

.blog-card__link:hover {
    gap: 0.7rem;
}

.pagination {
    display: flex;
    justify-content: center;
    gap: 10px;
    align-items: center;
}
.page-number, .pagination a {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid #ddd;
    color: #555;
    text-decoration: none;
}
.pagination a.btn-outline {
    width: auto;
    padding: 0 1rem;
    border-radius: 4px;
}
.page-number.active {
    background: #c9a84c;
    border-color: #c9a84c;
    color: #fff;
}
</style>