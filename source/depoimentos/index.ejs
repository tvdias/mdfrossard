---
title: Histórias Reais | MD Frossard Odontologia
layout: layout.ejs
description: Veja Histórias Reais de pacientes da Clínica MD Frossard Odontologia. Leia os comentários sobre o atendimento com os profissionais.
---

<!-- Page Mini Hero -->
<section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="container page-hero-content reveal">
        <h1>Histórias Reais</h1>
        <p>Veja o que nossos pacientes dizem sobre a experiência de cuidar do sorriso conosco.</p>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials section bg-light" id="depoimentos">
    <div class="container">
        <div class="section-header text-center reveal">
            <h2>O que nossos pacientes dizem</h2>
            <p>Confira os relatos de quem transformou o sorriso com a MD Frossard Odontologia.</p>
        </div>
        
        <div class="testimonials-grid mt-5">
            <% testimonials.forEach(function(item, index) { %>
            <div class="testimonial-card reveal delay-<%= (index % 3) + 1 %>">
                <div class="stars">
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                </div>
                <p class="testimonial-text">"<%= item.text %>"</p>
                <div class="testimonial-author">
                    <div class="author-avatar"><%= item.author.charAt(0) %></div>
                    <div>
                        <h4><%= item.author %></h4>
                        <span>Paciente</span>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Google Reviews CTA -->
        <div class="text-center mt-5 pt-5 reveal">
            <div class="google-reviews-box p-5 bg-white rounded-box shadow-sm">
                <div class="d-flex flex-column align-items-center">
                    <div class="google-icon-wrapper mb-3">
                        <i data-lucide="star" class="icon-lg text-warning"></i>
                        <i data-lucide="star" class="icon-lg text-warning"></i>
                        <i data-lucide="star" class="icon-lg text-warning"></i>
                        <i data-lucide="star" class="icon-lg text-warning"></i>
                        <i data-lucide="star" class="icon-lg text-warning"></i>
                    </div>
                    <h3>Gostou do nosso atendimento?</h3>
                    <p class="mb-4">Sua avaliação no Google é fundamental para nós. Confira o que dizem mais de 100 pacientes sobre nossa unidade na Barra da Tijuca.</p>
                    <a href="https://www.google.com/maps/place/MD+Frossard+Odontologia/@-23.002267,-43.3225709,17z" target="_blank" rel="noopener" class="btn btn-primary btn-lg d-inline-flex align-items-center gap-2">
                        <i data-lucide="map-pin" class="icon-sm"></i>
                        <span>Ver Avaliações no Google Maps (Barra)</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.testimonial-card {
    height: 100%;
    display: flex;
    flex-direction: column;
}
.testimonial-text {
    flex-grow: 1;
}
.google-reviews-box {
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,0.05);
    transition: transform 0.3s ease;
    max-width: 700px;
    margin: 0 auto;
}
.google-reviews-box:hover {
    transform: translateY(-5px);
}
.rounded-box {
    border-radius: 20px;
}
</style>
