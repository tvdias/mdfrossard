---
layout: layout.ejs
id: home
title: Dentista Na Barra da Tijuca e Botafogo
description: >-
  Dentista na Barra da tijuca e em Botafogo. A Clínica odontológica MD Frossard pode mudar seu sorriso. Confira a nossa filosofia de atendimento.
active_menu: home
hide_title: true
---

<!-- Hero Section -->
<section class="hero">
    <div class="hero-bg">
        <img src="/images/hero-img.webp" alt="Clínica MD Frossard" fetchpriority="high" loading="lazy" decoding="async" width="1600" height="1066">
        <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
        <div class="hero-text reveal">
            <h1>Seu sorriso levado a sério,<br>com tecnologia e conforto.</h1>
            <p>Equipe qualificada para devolver o seu sorriso sua autoestima. Tratamentos completos na Barra da Tijuca e Botafogo.</p>
            <div class="hero-buttons">
                <a href="tel:21976637803" onclick="return gtagSendEventTelefone(this.href)" class="btn btn-primary btn-lg">Marque sua Avaliação</a>
            </div>
        </div>
        <div class="hero-card reveal delay-1">
            <div class="glass-card">
                <i data-lucide="calendar-check" class="card-icon"></i>
                <h3>Agendamento Rápido</h3>
                <p>Fale diretamente com nossa equipe pelo WhatsApp e escolha o melhor horário.</p>
                <a href="https://api.whatsapp.com/send?phone=5521976637803" onclick="return gtagSendEventWhatsapp(this.href)"
                    class="text-link">Chamar no WhatsApp <i data-lucide="arrow-right" class="icon-xs"></i></a>
            </div>
        </div>
    </div>
</section>

<!-- Services / Teasers Section -->
<section class="features section">
    <div class="container">
        <div class="section-header reveal">
            <h2>Descubra a Experiência MD Frossard</h2>
            <p>Nossa filosofia de atendimento une excelência clínica a um ambiente acolhedor e seguro.</p>
        </div>

        <div class="grid grid-4">
            <a href="/depoimentos/" class="feature-card reveal delay-1">
                <div class="card-img">
                    <img src="/images/estrutura_new.webp" alt="Depoimentos" loading="lazy" decoding="async" width="800" height="533">
                    <div class="card-overlay">
                        <span>Ler Histórias</span>
                    </div>
                </div>
                <div class="card-content">
                    <h3>Depoimentos</h3>
                    <p>O que nossos pacientes dizem sobre nós.</p>
                </div>
            </a>

            <a href="/estrutura/" class="feature-card reveal delay-2">
                <div class="card-img">
                    <img src="/images/depoimentos_new.webp" alt="Estrutura" loading="lazy" decoding="async" width="800" height="533">
                    <div class="card-overlay">
                        <span>Conhecer</span>
                    </div>
                </div>
                <div class="card-content">
                    <h3>Nossa Estrutura</h3>
                    <p>Ambiente pensado para o seu bem-estar.</p>
                </div>
            </a>

            <a href="/equipe/" class="feature-card reveal delay-3">
                <div class="card-img">
                    <img src="/images/equipe.webp" alt="Equipe MD Frossard" loading="lazy" decoding="async" width="1400" height="933">
                    <div class="card-overlay">
                        <span>Conhecer</span>
                    </div>
                </div>
                <div class="card-content">
                    <h3>Equipe Especializada</h3>
                    <p>Profissionais em constante atualização.</p>
                </div>
            </a>

            <a href="tel:21976637803" onclick="return gtagSendEventTelefone(this.href)" class="feature-card reveal delay-4">
                <div class="card-img">
                    <img src="/images/consulta_new.webp" style="object-position: top center;" alt="Marque sua consulta" loading="lazy" decoding="async" width="533" height="800">
                    <div class="card-overlay">
                        <span>Agendar</span>
                    </div>
                </div>
                <div class="card-content">
                    <h3>Marque a sua consulta</h3>
                    <p>Dê o primeiro passo para o seu novo sorriso.</p>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="testimonials section bg-light" id="depoimentos">
    <div class="container">
        <div class="section-header reveal">
            <h2>O que nossos pacientes dizem</h2>
            <p>Histórias reais de sorrisos transformados pela MD Frossard Odontologia.</p>
        </div>
        
        <div class="testimonials-grid">
            <% site.data.testimonials.slice(0, 3).forEach(function(testimonial, index) { %>
            <div class="testimonial-card reveal delay-<%= index + 1 %>">
                <div class="stars">
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                    <i data-lucide="star" class="icon-sm star-filled"></i>
                </div>
                <p class="testimonial-text">"<%= testimonial.content %>"</p>
                <div class="testimonial-author">
                    <div class="author-avatar"><%= testimonial.name.charAt(0) %></div>
                    <div>
                        <h4><%= testimonial.name %></h4>
                        <span><%= testimonial.role || 'Paciente' %></span>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- Seção Local SEO: Nossas Unidades -->
